# Authentication (dev stub uses bypass token)
AUTH_SECRET=dev-only-secret-change-in-prod
NEXTAUTH_URL=http://localhost:3001

# Integration toggle (false = use stub data, true = call real APIs)
USE_LIVE_APIS=false

# Claude API (optional — used by MVP B for real-time OCR of new invoices)
ANTHROPIC_API_KEY=

# Real integrations (fill when available — left empty uses stubs)
LOGUE_TRANS_API_URL=
LOGUE_TRANS_API_KEY=
FROTCOM_API_URL=
FROTCOM_API_KEY=
PHC_INTEGRATOR_URL=
PHC_INTEGRATOR_KEY=
SEPSA_API_URL=
SEPSA_API_KEY=
REPSOL_API_URL=
REPSOL_API_KEY=
ANAMOR_API_URL=
ANAMOR_API_KEY=

# Storage (prod uses Azure Blob EU or R2 EU; dev uses local filesystem)
STORAGE_DRIVER=local
STORAGE_PATH=./uploads
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=

# Email (prod)
RESEND_API_KEY=
